# Copier ce fichier en .env.local puis remplir les valeurs.
# .env.local est ignoré par git (voir .gitignore) — ne jamais committer les clés.
# Sur Vercel, définir ces mêmes variables dans Project Settings → Environment Variables.

# --- Anthropic (génération des portraits, feedback, classification, Charlie) ---
ANTHROPIC_API_KEY=

# --- Upstash Redis (stockage des sessions, TTL 7 jours) ---
# Ces deux variables sont générées automatiquement si tu relies un store
# Upstash à ton projet Vercel (Storage → Connect).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Resend (email de récap — dépendance installée, câblage prévu semaine 3) ---
RESEND_API_KEY=
